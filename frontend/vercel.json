{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index"
    },
    {
      "source": "/login",
      "destination": "/pages/auth/login"
    },
    {
      "source": "/register",
      "destination": "/pages/auth/register"
    },
    {
      "source": "/forgot-password",
      "destination": "/pages/auth/forgot-password"
    },
    {
      "source": "/reset-password",
      "destination": "/pages/auth/reset-password"
    },
    {
      "source": "/profile-setup",
      "destination": "/pages/onboarding/profile-setup"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/main/dashboard"
    },
    {
      "source": "/chat",
      "destination": "/pages/main/chat"
    },
    {
      "source": "/music",
      "destination": "/pages/main/music"
    },
    {
      "source": "/vault",
      "destination": "/pages/main/vault"
    },
    {
      "source": "/settings",
      "destination": "/pages/main/settings"
    },
    {
      "source": "/profile",
      "destination": "/pages/main/profile"
    },
    {
      "source": "/about",
      "destination": "/pages/main/about"
    },
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/js/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    }
  ]
}
